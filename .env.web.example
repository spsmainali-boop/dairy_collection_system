# Copy this file to `.env.web` and fill in real values, then run:
#   ./scripts/run_web.sh
#
# `.env.web` is for LOCAL USE ONLY — it's already covered by the .gitignore
# entry below; never commit real Supabase keys to source control.

# --- Option A: your cloud Supabase project (from Settings -> API) ---
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR-ANON-KEY

# --- Option B: fully local Supabase stack (see scripts/local_supabase_start.sh) ---
# After running `supabase start`, the CLI prints a local URL + anon key that
# look like this — uncomment and use them instead of Option A:
# SUPABASE_URL=http://127.0.0.1:54321
# SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9....

# Port the local web server / flutter run listens on
WEB_PORT=8080
